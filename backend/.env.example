# Copy to backend/.env and fill in. DO NOT commit .env.

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Supabase (service-role key; backend only, never ship to browser) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Vapi ---
VAPI_API_KEY=
VAPI_PUBLIC_KEY=

# --- CORS / frontend URL ---
FRONTEND_URL=http://localhost:3000

# --- GitHub Actions shared secret for /api/scrape cron ---
SCRAPE_SHARED_SECRET=

# --- Email provider (filled on Day 5) ---
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM=

# --- Google OAuth (filled on Day 5; used by Calendar + Sheets APIs and Gmail MCP) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
