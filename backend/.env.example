# Copy to backend/.env and fill in. DO NOT commit .env.
# Schema must stay in lockstep with app/config.py::Settings.

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Supabase (service-role key; backend only, never ship to browser) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- CORS / frontend URL ---
FRONTEND_URL=http://localhost:3000
# Optional regex matched against the Origin header for additional allowed origins.
# Use to allow Vercel preview deploys, e.g.:
#   FRONTEND_ORIGIN_REGEX=https://[a-z0-9-]+-<vercel-scope>\.vercel\.app
FRONTEND_ORIGIN_REGEX=

# --- Vapi ---
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
# Random 32-char string; mirror the same value in the Vapi server-URL header
VAPI_WEBHOOK_SECRET=

# --- GitHub Actions shared secrets ---
# Random 32-char string; sent by .github/workflows/weekly-scrape.yml
SCRAPE_SHARED_SECRET=
# Random 32-char string; sent by .github/workflows/daily-corpus-refresh.yml
CORPUS_REFRESH_SECRET=

# --- Email provider (Resend by default; swap inside core/notifier.py for SendGrid/SES) ---
EMAIL_API_KEY=
EMAIL_FROM=
# Resend-specific key; falls back to EMAIL_API_KEY
RESEND_API_KEY=

# --- Google APIs (post-approval Calendar + Sheets execution) ---
# Either set GOOGLE_SA_JSON to the inline service-account JSON, OR set
# GOOGLE_SA_JSON_PATH to a file path. Inline wins if both are set.
GOOGLE_SA_JSON=
GOOGLE_SA_JSON_PATH=
GOOGLE_CALENDAR_ID=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_RANGE=Bookings!A:F

# --- Gmail MCP server (post-approval email draft via core/mcp_client.py) ---
# Example: GMAIL_MCP_COMMAND=npx, GMAIL_MCP_ARGS=-y,@your/gmail-mcp-server
GMAIL_MCP_COMMAND=
GMAIL_MCP_ARGS=

# --- Advisor inbox (Pillar C email draft recipient) ---
# Approved bookings drop a draft into this advisor's Gmail (via the MCP server)
# carrying the topic, IST slot, and a topic-relevant pulse snippet. Leave blank
# to fall back to the booking user's contact email (legacy behavior).
ADVISOR_EMAIL=
